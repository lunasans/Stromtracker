# .env.example
# Kopiere diese Datei nach ".env" und trage echte Werte ein.
# Die .env-Datei ist per .gitignore ausgeschlossen und darf NICHT committet werden.

# --- Datenbank ---
DB_HOST=localhost
DB_NAME=stromtracker
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Sicherheit ---
# Zufälligen Wert erzeugen, z.B.: php -r "echo bin2hex(random_bytes(32));"
CSRF_SECRET=change-me-to-a-random-secret

# --- Sonstiges ---
# Session-Lebensdauer in Sekunden (Standard: 24h)
SESSION_LIFETIME=86400
# Debug-Logging der API-Endpunkte (true/false)
API_DEBUG=false
